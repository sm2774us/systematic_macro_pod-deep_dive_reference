# =============================================================================
# .gitignore — Quant Alpha Research Monorepo
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage*.xml
coverage*.json
coverage-python.xml
htmlcov/
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------------------
# C++ / CMake
# ---------------------------------------------------------------------------
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
*.cmake
!CMakeLists.txt
*.o
*.a
*.so
*.so.*
*.dylib
*.out
*.exe
coverage-cpp*.info
*.gcno
*.gcda
*.gcov

# ---------------------------------------------------------------------------
# Bazel
# ---------------------------------------------------------------------------
bazel-bin/
bazel-genfiles/
bazel-out/
bazel-quant_alpha/
bazel-testlogs/
.bazel/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Secrets / Environment
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ---------------------------------------------------------------------------
# Research artefacts (data not committed)
# ---------------------------------------------------------------------------
data/raw/
data/processed/
*.parquet
*.csv.gz
*.feather
*.arrow
backtest_results/
kpi_metrics.json

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
